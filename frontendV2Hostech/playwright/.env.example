# Sao chép thành `playwright/.env` (file này không commit).
# Lấy email tenant từ DB (org tên "test"):
#
#   cd ../backend && php artisan tinker --execute="echo optional(\App\Models\Org\Org::where('name','test')->first()) ? (\App\Models\Org\User::role('Tenant')->where('org_id', \App\Models\Org\Org::where('name','test')->first()->id)->orderBy('email')->value('email') ?? 'NO_TENANT') : 'NO_ORG';"
#
E2E_TENANT_EMAIL=
