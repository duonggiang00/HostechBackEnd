SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Playwright / máy dev không chạy Reverb: dùng `log` để tránh 500 khi gửi duyệt chốt số (broadcast).
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# database + `composer dev` (có queue:listen) — sync sơ đồ tạo nhiều phòng: khởi tạo meter/giá chạy job nền, XHR nhanh hơn.
# sync = mọi thứ chạy trong request; vẫn có debounce bust cache overview trong cùng request.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
